@model List<Review>

@{
	ViewData["Title"] = "ReviewList";
	Layout = "~/Views/Shared/_AdminLayout.cshtml";
	int currentPage = @ViewBag.CurrentPage;
	int pageSize = @ViewBag.PageSize;

	int count = (currentPage - 1) * pageSize;
}

<section class="content">

	<div class="block-header">
		<div class="row">
			<div class="col-lg-7 col-md-6 col-sm-12">
				<h2>
					Yorum Listesi
					<small class="text-muted">Yorum İşlemleri Sayfası</small>
				</h2>
			</div>
			<div class="col-lg-5 col-md-6 col-sm-12">
				<ul class="breadcrumb float-md-right">
					<li class="breadcrumb-item"><a href="index.html"><i class="zmdi zmdi-home"></i> Yorumlar</a></li>
					<li class="breadcrumb-item"><a href="javascript:void(0);">Yorum Listesi</a></li>
					<li class="breadcrumb-item active">Ana Sayfa</li>
				</ul>
			</div>
		</div>
	</div>

	<div class="container-fluid">
		<div class="row clearfix">
			<div class="col-lg-12">
				<div class="card">
					<div class="body">

						<table class="table table-bordered">
							<tr>
								<th>#</th>
								<th>Müşteri Adı</th>
								<th>Ürün Adı</th>
								<th>Satın Alım Türü</th>
								<th>Puan</th>
								<th>Duygu</th>
								<th>Yorum</th>
								<th>Tarihi</th>
								<th>Sil</th>
								<th>Güncelle</th>
							</tr>

							@foreach (var item in Model)
							{
								count++;
								<tr>
									<td>@count</td>
									<td>@item.Customer.CustomerName @item.Customer.CustomerSurname</td>
									<td>@item.Product.ProductName</td>
									<td>@item.PurchaseType</td>
									<td>@item.Rating</td>
									<td>@item.Sentiment</td>
									<td>@item.ReviewText</td>
									<td>@item.ReviewDate.ToString("dd/MM/yyyy")</td>
									<td>
										<form id="deleteForm_@item.ReviewId" asp-action="DeleteReview" method="post" style="display:inline;">
											@Html.AntiForgeryToken()

											<input type="hidden" name="id" value="@item.ReviewId" />
											<button type="button" class="btn btn-danger btn-sm delete-btn" data-id="@item.ReviewId" data-reviewer-name="@item.Customer.CustomerName @item.Customer.CustomerSurname">Sil</button>
										</form>
									</td>
									<td><a href="/Review/UpdateReview/@item.ReviewId" class="btn btn-success">Güncelle</a></td>
								</tr>
							}

						</table>

						<div class="mt-3 text-center">
							<nav aria-label="Page navigation">
								<ul class="pagination justify-content-center">

									@if (ViewBag.CurrentPage > 1)
									{
										<li class="page-item">
											<a class="page-link" href="/Review/ReviewList?page=@(ViewBag.CurrentPage - 1)">Önceki</a>
										</li>
									}

									@{
										int startPage = Math.Max(1, ViewBag.CurrentPage - 2);
										int endPage = Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + 2);

										if (startPage > 1)
										{
											<li class="page-item">
												<a class="page-link" href="/Review/ReviewList?page=1">1</a>
											</li>
											if (startPage > 2)
											{
												<li class="page-item disabled">
													<span class="page-link">...</span>
												</li>
											}
										}

										for (int i = startPage; i <= endPage; i++)
										{
											<li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
												<a class="page-link" href="/Review/ReviewList?page=@i">@i</a>
											</li>
										}

										if (endPage < ViewBag.TotalPages)
										{
											if (endPage < ViewBag.TotalPages - 1)
											{
												<li class="page-item disabled">
													<span class="page-link">...</span>
												</li>
											}
											<li class="page-item">
												<a class="page-link" href="/Review/ReviewList?page=@ViewBag.TotalPages">@ViewBag.TotalPages</a>
											</li>
										}
									}

									@if (ViewBag.CurrentPage < ViewBag.TotalPages)
									{
										<li class="page-item">
											<a class="page-link" href="/Review/ReviewList?page=@(ViewBag.CurrentPage + 1)">Sonraki</a>
										</li>
									}

								</ul>
							</nav>
						</div>

						<a href="/Review/AddReview/" class="btn btn-info">Yeni Yorum Girişi</a>

					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<script>
			document.querySelectorAll('.delete-btn').forEach(button => {
		button.addEventListener('click', function() {
			const reviewId = this.getAttribute('data-id');
			const reviewerName = this.getAttribute('data-reviewer-name');

			const form = document.getElementById(`deleteForm_${reviewId}`);

			Swal.fire({
				title: 'Emin misiniz?',
				text: `${reviewerName} müşterisinin yorumu kalıcı olarak silinecek.`,
				icon: 'warning',
				showCancelButton: true,
				confirmButtonColor: '#d33',
				cancelButtonColor: '#3085d6',
				confirmButtonText: 'Evet, Sil!',
				cancelButtonText: 'Vazgeç'
			}).then((result) => {
				if (result.isConfirmed) {
					form.submit();
				}
			});
		});
	});
</script>

