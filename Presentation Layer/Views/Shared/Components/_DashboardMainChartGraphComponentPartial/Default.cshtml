@model List<MonthlySalesDto>

<div class="card">
    <div class="body">
        <h4>Son 6 Aylık Satış Durumları</h4>
        <canvas id="salesStatusChart"></canvas>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const ctx = document.getElementById('salesStatusChart').getContext('2d');

        // C# Listesinden Adetleri (Count) ve Tutarları (Amount) JavaScript'e aktarıyoruz
        const monthLabels = @Html.Raw(Json.Serialize(Model.Select(x => x.MonthName)));

        // Tutarlar (Grafik çizgileri için)
        const completedAmounts = @Html.Raw(Json.Serialize(Model.Select(x => x.CompletedAmount)));
        const cancelledAmounts = @Html.Raw(Json.Serialize(Model.Select(x => x.CancelledAmount)));
        const shippedAmounts = @Html.Raw(Json.Serialize(Model.Select(x => x.ShippedAmount)));

        // Adetler (Tooltip'te göstermek için)
        const completedCounts = @Html.Raw(Json.Serialize(Model.Select(x => x.CompletedCount)));
        const cancelledCounts = @Html.Raw(Json.Serialize(Model.Select(x => x.CancelledCount)));
        const shippedCounts = @Html.Raw(Json.Serialize(Model.Select(x => x.ShippedCount)));

        const data = {
            labels: monthLabels,
            datasets: [
                {
                    label: 'Tamamlanan Satışlar',
                    data: completedAmounts,
                    customCounts: completedCounts, // Özel veriyi buraya gömdük
                    fill: true,
                    backgroundColor: 'rgba(76, 175, 80, 0.2)',
                    borderColor: 'rgba(76, 175, 80, 1)',
                    borderWidth: 2,
                    pointRadius: 4,
                    tension: 0.4
                },
                {
                    label: 'İptal Edilen Satışlar',
                    data: cancelledAmounts,
                    customCounts: cancelledCounts,
                    fill: true,
                    backgroundColor: 'rgba(244, 67, 54, 0.2)',
                    borderColor: 'rgba(244, 67, 54, 1)',
                    borderWidth: 2,
                    pointRadius: 4,
                    tension: 0.4
                },
                {
                    label: 'Kargodaki Satışlar',
                    data: shippedAmounts,
                    customCounts: shippedCounts,
                    fill: true,
                    backgroundColor: 'rgba(255, 193, 7, 0.2)',
                    borderColor: 'rgba(255, 193, 7, 1)',
                    borderWidth: 2,
                    pointRadius: 4,
                    tension: 0.4
                }
            ]
        };

        const options = {
            responsive: true,
            plugins: {
                tooltip: {
                    callbacks: {
                        label: function(context) {
                            let label = context.dataset.label || '';
                            let index = context.dataIndex;
                            let count = context.dataset.customCounts[index]; // O aya ait adedi çekiyoruz
                            let amount = context.parsed.y;

                            if (label) { label += ': '; }

                            // Tutar formatlama
                            let formattedAmount = new Intl.NumberFormat('tr-TR', {
                                style: 'currency',
                                currency: 'TRY'
                            }).format(amount);

                            // Tooltip çıktısı: "Tamamlanan Satışlar: ₺15.000,00 (12 Adet)"
                            return `${label} ${formattedAmount} (${count} Adet)`;
                        }
                    }
                }
            },
            scales: {
                y: { beginAtZero: true },
                x: { grid: { display: false } }
            }
        };

        new Chart(ctx, {
            type: 'line',
            data: data,
            options: options
        });
    });
</script>