@model List<MonthlySalesDto>


    <div class="card-body">
        <h5 class="card-title text-muted mb-4">Son 6 Aylık Sipariş Grafiği</h5>
        <div style="height: 400px;">
            <canvas id="salesStatusChart"></canvas>
        </div>
    </div>


<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const ctx = document.getElementById('salesStatusChart').getContext('2d');

        // C# Verilerini JavaScript'e Aktarma
        const labels = @Html.Raw(Json.Serialize(Model.Select(x => x.MonthName)));

        const counts = {
            completed: @Html.Raw(Json.Serialize(Model.Select(x => x.CompletedCount))),
            cancelled: @Html.Raw(Json.Serialize(Model.Select(x => x.CancelledCount))),
            shipped: @Html.Raw(Json.Serialize(Model.Select(x => x.ShippedCount)))
        };

        const amounts = {
            completed: @Html.Raw(Json.Serialize(Model.Select(x => x.CompletedAmount))),
            cancelled: @Html.Raw(Json.Serialize(Model.Select(x => x.CancelledAmount))),
            shipped: @Html.Raw(Json.Serialize(Model.Select(x => x.ShippedAmount)))
        };

        const data = {
            labels: labels,
            datasets: [
                {
                    label: 'Tamamlanan',
                    data: counts.completed,
                    extraAmounts: amounts.completed,
                    borderColor: '#4caf50',
                    backgroundColor: 'rgba(76, 175, 80, 0.1)',
                    fill: true,
                    tension: 0.4,
                    pointRadius: 4
                },
                {
                    label: 'İptal Edilen',
                    data: counts.cancelled,
                    extraAmounts: amounts.cancelled,
                    borderColor: '#f44336',
                    backgroundColor: 'rgba(244, 67, 54, 0.1)',
                    fill: true,
                    tension: 0.4,
                    pointRadius: 4
                },
                {
                    label: 'Kargoda',
                    data: counts.shipped,
                    extraAmounts: amounts.shipped,
                    borderColor: '#ffc107',
                    backgroundColor: 'rgba(255, 193, 7, 0.1)',
                    fill: true,
                    tension: 0.4,
                    pointRadius: 4
                }
            ]
        };

        const options = {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    position: 'top',
                    labels: { usePointStyle: true, pointStyle: 'circle' }
                },
                tooltip: {
                    callbacks: {
                        label: function(context) {
                            let label = context.dataset.label || '';
                            let count = context.parsed.y;
                            let amount = context.dataset.extraAmounts[context.dataIndex];

                            let formattedAmount = new Intl.NumberFormat('tr-TR', {
                                style: 'currency', currency: 'TRY'
                            }).format(amount);

                            return `${label}: ${count} Adet (Toplam: ${formattedAmount})`;
                        }
                    }
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    min: 0,
                    max: 10000, // Y ekseni tavan değeri
                    ticks: {
                        stepSize: 1000, // 1000'er birimlik artış
                        color: '#666'
                    },
                    grid: {
                        color: 'rgba(0, 0, 0, 0.05)' // Hafif ızgara çizgileri
                    },
                    title: {
                        display: true,
                        text: 'Sipariş Adedi'
                    }
                },
                x: {
                    grid: { display: false },
                    ticks: { color: '#666' }
                }
            }
        };

        new Chart(ctx, {
            type: 'line',
            data: data,
            options: options
        });
    });
</script>