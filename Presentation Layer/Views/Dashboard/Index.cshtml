@{
	ViewData["Title"] = "Index";
	Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<section class="content">

	@await Component.InvokeAsync("_DashboardBlockHeaderComponentPartial")

	<div class="container-fluid">

		@await Component.InvokeAsync("_DashboardFirstChartsComponentPartial")

		<br />

		<div class="row clearfix">
			<div class="col-lg-9 col-md-8">
				<div class="card product-report">
					@await Component.InvokeAsync("_DashboardMainChartComponentPartial")
					@await Component.InvokeAsync("_DashboardMainChartGraphComponentPartial")
				</div>

			</div>


			@await Component.InvokeAsync("_DashboardKpiComponentPartial")

		</div>
		
		@await Component.InvokeAsync("_DashboardSubStatisticsComponentPartial")

		@await Component.InvokeAsync("_DashboardMapComponentPartial")
		<br />
		<br />

		<div class="row clearfix">

			@await Component.InvokeAsync("_DashboardLast5ReviewsComponentPartial")
			
			@await Component.InvokeAsync("_DashboardCriticalStockStatusProductsComponentPartial")

			<div class="col-lg-4 col-md-6 col-sm-12">
				<div class="card">
					<div class="header">
						<h2>Browser Usage</h2>
						<ul class="header-dropdown m-r--5">
							<li class="dropdown">
								<a href="javascript:void(0);" class="dropdown-toggle" data-toggle="dropdown" role="button" aria-haspopup="true" aria-expanded="false"> <i class="zmdi zmdi-more-vert"></i> </a>
								<ul class="dropdown-menu slideUp ">
									<li><a href="javascript:void(0);">Action</a></li>
									<li><a href="javascript:void(0);">Another action</a></li>
									<li><a href="javascript:void(0);">Something else</a></li>
								</ul>
							</li>
						</ul>
					</div>
					<div class="body">
						<div id="donut_chart" class="dashboard-donut-chart"></div>
						<table class="table m-t-15 m-b-0">
							<tbody>
								<tr>
									<td>1</td>
									<td>Chrome</td>
									<td>6985</td>
									<td><i class="zmdi zmdi-caret-up text-success"></i></td>
								</tr>
								<tr>
									<td>2</td>
									<td>Other</td>
									<td>2697</td>
									<td><i class="zmdi zmdi-caret-up text-success"></i></td>
								</tr>
								<tr>
									<td>3</td>
									<td>Safari</td>
									<td>3597</td>
									<td><i class="zmdi zmdi-caret-down text-danger"></i></td>
								</tr>
								<tr>
									<td>4</td>
									<td>Firefox</td>
									<td>2145</td>
									<td><i class="zmdi zmdi-caret-up text-success"></i></td>
								</tr>
								<tr>
									<td>5</td>
									<td>Opera</td>
									<td>1854</td>
									<td><i class="zmdi zmdi-caret-down text-danger"></i></td>
								</tr>
							</tbody>
						</table>
					</div>
				</div>
			</div>
		</div>

		@await Component.InvokeAsync("_DashboardTodayOrdersComponentPartial")

	</div>
</section>

