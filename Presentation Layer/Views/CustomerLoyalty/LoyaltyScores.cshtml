@model CustomerLoyaltyViewModel

@{
    ViewData["Title"] = "LoyaltyScores";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<section class="content">
    <div class="block-header">
        <div class="row">
            <div class="col-lg-7 col-md-6 col-sm-12">
                <h2>
                    @Model.SelectedCountry - @Model.SelectedCity: Sadakat Analizi
                    <small class="text-muted">RFM (Recency, Frequency, Monetary) Tabanlı Akıllı Puanlama</small>
                </h2>
            </div>
            <div class="col-lg-5 col-md-6 col-sm-12">
                <ul class="breadcrumb float-md-right">
                    <li class="breadcrumb-item"><a href="/Dashboard/Index"><i class="zmdi zmdi-home"></i> Analitik</a></li>
                    <li class="breadcrumb-item active">Sadakat Skorları</li>
                </ul>
            </div>
        </div>
    </div>

    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-lg-12">
                <div class="card">
                    <div class="body">
                        <form asp-action="LoyaltyScores" method="get" id="loyaltyFilterForm">
                            <div class="row">
                                <div class="col-md-3">
                                    <label>Ülke Filtresi:</label>
                                    <select name="countryName" class="form-control show-tick" onchange="this.form.submit()">
                                        @foreach (var country in Model.Countries)
                                        {
                                            <option value="@country" selected="@(country == Model.SelectedCountry ? "selected" : null)">@country</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label>Şehir Filtresi:</label>
                                    <select name="cityName" class="form-control show-tick" onchange="this.form.submit()">
                                        @foreach (var city in Model.Cities)
                                        {
                                            <option value="@city" selected="@(city == Model.SelectedCity ? "selected" : null)">@city</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-6 text-right">
                                    <div class="p-t-10">
                                        <span class="text-muted">Bölgesel Ortalama: </span>
                                        <h3 class="d-inline text-success m-l-10">
                                            @(Model.LoyaltyScores.Any() ? Model.LoyaltyScores.Average(x => x.LoyaltyScore).ToString("0.0") : "0")
                                        </h3>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <div class="row clearfix">
            <div class="col-lg-12">
                <div class="card">
                    <div class="header">
                        <h2><strong>@Model.SelectedCity</strong> Müşteri Segmentasyonu</h2>
                    </div>
                    <div class="body">
                        <div class="table-responsive">
                            <table class="table table-hover table-bordered text-center">
                                <thead>
                                    <tr class="bg-blue text-white">
                                        <th>Sıra</th>
                                        <th>Müşteri Adı</th>
                                        <th>Sipariş Sıklığı (F)</th>
                                        <th>Harcama Hacmi (M)</th>
                                        <th>Son Etkileşim (R)</th>
                                        <th>Sadakat Puanı</th>
                                        <th>Segment</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.LoyaltyScores != null && Model.LoyaltyScores.Any())
                                    {
                                        int rank = 1;
                                        foreach (var item in Model.LoyaltyScores)
                                        {
                                            string badgeClass;
                                            string segmentName;
                                            string scoreColor;

                                            if (item.LoyaltyScore >= 80) { badgeClass = "badge-success"; segmentName = "ELITE"; scoreColor = "text-success"; }
                                            else if (item.LoyaltyScore >= 50) { badgeClass = "badge-primary"; segmentName = "LOYAL"; scoreColor = "text-primary"; }
                                            else if (item.LoyaltyScore >= 25) { badgeClass = "badge-warning"; segmentName = "AT RISK"; scoreColor = "text-warning"; }
                                            else { badgeClass = "badge-danger"; segmentName = "HIBERNATING"; scoreColor = "text-danger"; }

                                            <tr>
                                                <td><strong>#@rank</strong></td>
                                                <td class="text-left"><strong>@item.CustomerName</strong></td>
                                                <td><span class="badge badge-info">@item.OrderCount ADET</span></td>
                                                <td class="font-bold text-dark">@item.TotalSpend.ToString("C2")</td>
                                                <td>@(item.LastOrderDate.HasValue? item.LastOrderDate.Value.ToString("dd.MM.yyyy") : "Veri Yok")</td>
                                                <td class="@scoreColor font-20 font-bold">@item.LoyaltyScore.ToString("0.00")</td>
                                                <td>
                                                    <span class="badge @badgeClass" style="font-size: 11px; padding: 6px 12px; min-width: 90px;">
                                                        @segmentName
                                                    </span>
                                                </td>
                                            </tr>
                                            rank++;
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="7" class="p-40 text-muted">Bu bölge için henüz analiz edilecek müşteri verisi bulunamadı.</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>