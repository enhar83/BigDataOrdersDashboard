@model GermanyCitiesForecastViewModel
@{
    ViewData["Title"] = "GermanCitiesForecast";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<section class="content">
    <div class="block-header">
        <div class="row">
            <div class="col-lg-7 col-md-6 col-sm-12">
                <h2>
                    Almanya Şehirleri: Geçmiş Veri ve Gelecek Tahmini
                    <small class="text-muted">2025 Yılı Gerçekleşen ve 2026 Yılı Tahmin Edilen Sipariş Sayıları</small>
                </h2>
            </div>
            <div class="col-lg-5 col-md-6 col-sm-12">
                <ul class="breadcrumb float-md-right">
                    <li class="breadcrumb-item"><a href="/Dashboard/Index"><i class="zmdi zmdi-home"></i> Tahminlemeler</a></li>
                    <li class="breadcrumb-item active">Sipariş Tahminleri</li>
                </ul>
            </div>
        </div>
    </div>

    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-lg-12">
                <div class="card">
                    <div class="header">
                        <h2><strong>Tahmin</strong> Tablosu</h2>
                    </div>
                    <div class="body">
                        <table class="table table-hover table-bordered">
                            <thead>
                                <tr class="bg-blue text-white">
                                    <th>Şehir Adı</th>
                                    <th>Dönem</th>
                                    <th>2025 Gerçekleşen (Adet)</th>
                                    <th>2026 Tahmin Edilen (Adet)</th>
                                    <th>Beklenen Fark</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.ForecastResults)
                                {
                                    var difference = item.PredictedCount - item.LastYearsCount;
                                    var badgeClass = difference >= 0 ? "badge-success" : "badge-danger";

                                    <tr>
                                        <td><strong>@item.CityName</strong></td>
                                        <td>@item.Month</td>
                                        <td class="text-center">@item.LastYearsCount</td>
                                        <td class="text-center text-primary"><strong>@item.PredictedCount</strong></td>
                                        <td class="text-center">
                                            <span class="badge @badgeClass">
                                                @(difference >= 0 ? "+" : "")@difference
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
