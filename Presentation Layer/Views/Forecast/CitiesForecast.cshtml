@model CitiesForecastViewModel
@{
    ViewData["Title"] = "CitiesForecast";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<section class="content">
    <div class="block-header">
        <div class="row">
            <div class="col-lg-7 col-md-6 col-sm-12">
                <h2>
                    @Model.SelectedCountry - @Model.SelectedCity: Geçmiş Veri ve Gelecek Tahmini
                    <small class="text-muted">2024-2025 Gerçekleşen ve 2026 Tahmin Edilen Değerler</small>
                </h2>
            </div>
            <div class="col-lg-5 col-md-6 col-sm-12">
                <ul class="breadcrumb float-md-right">
                    <li class="breadcrumb-item"><a href="/Dashboard/Index"><i class="zmdi zmdi-home"></i> Tahminlemeler</a></li>
                    <li class="breadcrumb-item active">Şehir Tahminleri</li>
                </ul>
            </div>
        </div>
    </div>

    <div class="container-fluid">
        <div class="row clearfix">
            <div class="col-lg-12">
                <div class="card">
                    <div class="body">
                        <form asp-action="CitiesForecast" method="get" id="forecastFilterForm">
                            <div class="row">
                                <div class="col-md-3">
                                    <label>Ülke Seçin:</label>
                                    <select name="countryName" class="form-control show-tick" onchange="this.form.submit()">
                                        @foreach (var country in Model.CountryNames)
                                        {
                                            <option value="@country" selected="@(country == Model.SelectedCountry ? "selected" : null)">@country</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label>Şehir Seçin:</label>
                                    <select name="cityName" class="form-control show-tick" onchange="this.form.submit()">
                                        @foreach (var city in Model.CityNames)
                                        {
                                            <option value="@city" selected="@(city == Model.SelectedCity ? "selected" : null)">@city</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-6 text-right">
                                    <h3 class="m-t-10">İnceleme: <span class="text-primary">@Model.SelectedCountry / @Model.SelectedCity</span></h3>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <div class="row clearfix">
            <div class="col-lg-12">
                <div class="card">
                    <div class="header">
                        <h2><strong>@Model.SelectedCity</strong> Projeksiyonu</h2>
                    </div>
                    <div class="body">
                        <div class="table-responsive">
                            <table class="table table-hover table-bordered text-center">
                                <thead>
                                    <tr class="bg-blue text-white">
                                        <th>Ay / Dönem</th>
                                        <th>2024 Gerçekleşen</th>
                                        <th>2025 Gerçekleşen</th>
                                        <th>2026 Tahmin Edilen</th>
                                        <th>Beklenen Fark (25'e Göre)</th>
                                        <th>Değişim Oranı (%)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.ForecastResults.Any())
                                    {
                                        foreach (var item in Model.ForecastResults)
                                        {
                                            var difference = item.PredictedCount - item.CountFor2025;
                                            var badgeClass = difference >= 0 ? "badge-success" : "badge-danger";

                                            <tr>
                                                <td><strong>@item.Month</strong></td>
                                                <td>@item.CountFor2024</td>
                                                <td>@item.CountFor2025</td>
                                                <td class="text-primary font-bold">@item.PredictedCount</td>
                                                <td>
                                                    <span class="badge @badgeClass" style="font-size: 14px; padding: 5px 10px;">
                                                        @(difference >= 0 ? "+" : "")@difference
                                                    </span>
                                                </td>
                                                <td>
                                                    <span class="text-@(difference >= 0 ? "success" : "danger") font-bold">
                                                        @(difference >= 0 ? "↑" : "↓") %@item.ChangeRate.ToString("0.0")
                                                    </span>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="6" class="text-center text-muted">Seçilen şehir için tahmin üretilemedi. (Veri hacmi yetersiz)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>